generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────

enum UserRole {
  PROVIDER
  WORKER
}

enum WorkerRole {
  RN
  LPN
  CNA
  HHA
  MEDICAL_ASSISTANT
  COMPANION
  OTHER
}

enum ShiftStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  UNPAID
  HELD
  RELEASED
  REFUNDED
}

enum StripeAccountStatus {
  NOT_STARTED
  PENDING
  ACTIVE
}

enum ComplianceStatus {
  PENDING
  COMPLETE
}

enum AgencyType {
  HOME_HEALTH
  HOSPICE
  HOSPITAL
  NURSE_REGISTRY
  STAFFING_COMPANY
  PRIVATE_EMPLOYER
}

enum AssignmentStatus {
  REQUESTED
  HELD
  ACCEPTED
  CONFIRMED
  REJECTED
  CANCELLED
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum ProviderType {
  AGENCY
  PRIVATE
}

enum CredentialType {
  LICENSE
  CERTIFICATION
  BACKGROUND_CHECK
  TB_TEST
  CPR
  OTHER
}

enum CredentialStatus {
  PENDING
  PROVISIONAL
  VERIFIED
  EXPIRED
  REJECTED
}

enum PayCadence {
  SAME_DAY    // Worker paid within hours of shift completion
  STANDARD    // Biweekly payout cycle (industry standard)
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── Models ──────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String
  passwordHash        String?
  role                UserRole?
  phone               String?
  avatarUrl           String?
  emailVerified       DateTime?
  timezone            String?   // IANA timezone e.g. "America/New_York"
  isActive            Boolean   @default(true)
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  isSuspended         Boolean   @default(false)
  suspendedAt         DateTime?

  workerProfile    WorkerProfile?
  providerProfile  ProviderProfile?
  shifts           Shift[]          @relation("ProviderShifts")
  assignedShifts   Shift[]          @relation("AssignedWorker")
  paymentMethods       PaymentMethod[]
  wallet               Wallet?
  providerTransactions Transaction[]    @relation("ProviderTransactions")
  workerTransactions   Transaction[]    @relation("WorkerTransactions")
  providerShiftPays    ShiftPayment[]   @relation("ProviderShiftPayments")
  workerShiftPays      ShiftPayment[]   @relation("WorkerShiftPayments")
  payouts              Payout[]
  notifications        Notification[]
  timeEntries          TimeEntry[]
  ratingsGiven         Rating[]         @relation("RatingsGiven")
  ratingsReceived      Rating[]         @relation("RatingsReceived")
  sessions         Session[]
  accounts         Account[]
  strikes              Strike[]
  pushSubscriptions    PushSubscription[]
  sentMessages         ShiftMessage[]   @relation("SentMessages")
  preferredByProviders PreferredWorker[] @relation("PreferredWorkers")
  preferredWorkers     PreferredWorker[] @relation("PreferredByProvider")
  credentialAlerts     CredentialAlert[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Provider Profile ────────────────────────────────────────────

model ProviderProfile {
  id                 String        @id @default(cuid())
  userId             String        @unique
  providerType       ProviderType  @default(AGENCY)
  companyName        String
  description        String?
  address            String?
  city               String?
  state              String?
  zipCode            String?
  phone              String?
  website            String?
  // Agency-specific fields
  npiNumber          String?
  einNumber          String?
  licenseNumber      String?
  licenseState       String?
  licenseExpiryDate  DateTime?
  agencyType         AgencyType?
  contactPerson      String?       // If different from the account holder
  contactTitle       String?
  contactPersonEmail String?
  contactPersonPhone String?
  // Stripe
  stripeCustomerId         String?
  defaultPaymentMethodId   String?
  // Subscription
  subscriptionStatus       SubscriptionStatus @default(ACTIVE)
  subscriptionPlan         SubscriptionPlan   @default(FREE)
  shiftsPostedThisMonth    Int                @default(0)
  onboardingComplete       Boolean            @default(false)
  // Compliance
  complianceStatus         ComplianceStatus   @default(PENDING)
  ahcaLicenseNumber        String?
  // Notification preferences
  notificationPrefs        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription?
  usageRecords UsageTracking[]

  @@map("provider_profiles")
}

// ─── Worker Profile ──────────────────────────────────────────────

model WorkerProfile {
  id                 String      @id @default(cuid())
  userId             String      @unique
  workerRole         WorkerRole?
  licenseNumber      String?
  licenseState       String?
  licenseExpiry      DateTime?
  certifications     String[]    @default([])
  bio                String?
  yearsExperience    Int?
  serviceRadiusMiles Int?
  city               String?
  state              String?
  zipCode            String?
  workAreas          String[]    @default([])  // Cities/areas the worker will travel to
  isAvailable          Boolean     @default(true)
  profileComplete      Boolean     @default(false)
  verificationDeadline DateTime?   // 30 days from signup — must upload docs by then
  verificationStatus   String      @default("pending") // pending, verified, suspended
  // Credential verification
  credentialStatus       CredentialStatus @default(PENDING)
  credentialDocumentKey  String?          // S3 file key of uploaded credential document
  credentialExpiryDate   DateTime?
  credentialSubmittedAt  DateTime?        // When docs were first submitted — 14-day provisional window starts here
  // Stripe Connect
  stripeAccountId        String?
  stripeAccountStatus    StripeAccountStatus @default(NOT_STARTED)
  // Performance
  reliabilityScore       Float?           // completed / accepted * 100
  shiftsCompleted        Int              @default(0)
  totalEarnings          Decimal          @default(0) @db.Decimal(10, 2)
  // Notification preferences
  notificationPrefs      Json?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments       Assignment[]
  availabilitySlots AvailabilitySlot[]
  credentials       Credential[]
  blockedDates      BlockedDate[]

  @@map("worker_profiles")
}

model AvailabilitySlot {
  id              String    @id @default(cuid())
  workerProfileId String
  dayOfWeek       DayOfWeek
  startTime       String    // "06:00" format
  endTime         String    // "18:00" format
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@index([workerProfileId, dayOfWeek])
  @@map("availability_slots")
}

model Credential {
  id               String           @id @default(cuid())
  workerProfileId  String
  type             CredentialType
  name             String
  licenseNumber    String?
  issuingAuthority String?
  issueDate        DateTime?
  expiryDate       DateTime?
  status           CredentialStatus @default(PENDING)
  documentUrl      String?
  verifiedAt       DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@index([workerProfileId])
  @@map("credentials")
}

// ─── Shifts ──────────────────────────────────────────────────────

model Shift {
  id               String      @id @default(cuid())
  providerId       String
  role             WorkerRole
  title            String?
  location         String
  latitude         Float?      // Geocoded from location address
  longitude        Float?      // Geocoded from location address
  geofenceRadius   Float       @default(0.5) // Miles — how close worker must be to clock in
  startTime        DateTime
  endTime          DateTime
  payRate          Float
  notes            String?
  status           ShiftStatus @default(OPEN)
  // Provider preferences — who can see/accept this shift
  minExperience    Int?        // Minimum years of experience (null = no minimum)
  minRating        Float?      // Minimum worker rating (null = no minimum) — reserved for future
  requirements     String[]    @default([]) // BLS/CPR, Hoyer Lift, etc.
  isUrgent         Boolean     @default(false)
  payCadence       PayCadence  @default(STANDARD) // Same-day or biweekly payout
  description      String?     @db.Text
  // Assignment tracking
  assignedWorkerId String?
  assignedAt       DateTime?
  // Payment / Escrow
  paymentStatus          PaymentStatus @default(UNPAID)
  stripePaymentIntentId  String?
  stripeTransferId       String?
  grossAmount            Decimal?  @db.Decimal(10, 2)
  platformFeeAmount      Decimal?  @db.Decimal(10, 2)
  workerPayoutAmount     Decimal?  @db.Decimal(10, 2)
  // Completion
  completionConfirmedAt  DateTime?
  completionConfirmedBy  String?
  // Dispute
  disputeReason          String?
  // Preferred worker invite system
  isPublic         Boolean     @default(true)
  inviteExpiresAt  DateTime?
  // Optimistic locking
  version          Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  provider       User         @relation("ProviderShifts", fields: [providerId], references: [id], onDelete: Cascade)
  assignedWorker User?        @relation("AssignedWorker", fields: [assignedWorkerId], references: [id], onDelete: SetNull)
  assignments    Assignment[]
  shiftPayment   ShiftPayment?
  transactions   Transaction[]
  timeEntries    TimeEntry[]
  ratings        Rating[]
  messages       ShiftMessage[]
  strikes        Strike[]

  @@index([providerId])
  @@index([status])
  @@index([role, status])
  @@index([startTime])
  @@index([assignedWorkerId])
  @@index([providerId, status])
  @@map("shifts")
}

// ─── Assignments ─────────────────────────────────────────────────

model Assignment {
  id              String           @id @default(cuid())
  shiftId         String
  workerProfileId String
  status          AssignmentStatus @default(REQUESTED)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  shift         Shift         @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  // Only one active assignment per worker per shift
  @@unique([shiftId, workerProfileId])
  @@index([shiftId])
  @@index([workerProfileId])
  @@map("assignments")
}

// ─── Time Entries (Clock-In) ─────────────────────────────────────

enum ClockInStatus {
  ON_SITE      // Within geofence radius
  OFF_SITE     // Outside geofence radius
  NO_LOCATION  // Worker denied location access
}

enum StrikeType {
  NO_SHOW
  LATE_CANCEL
}

model TimeEntry {
  id              String        @id @default(cuid())
  shiftId         String
  workerId        String
  clockInTime     DateTime
  clockInLat      Float?
  clockInLng      Float?
  clockInStatus   ClockInStatus @default(NO_LOCATION)
  distanceMiles   Float?        // Distance from shift location at clock-in
  clockOutTime    DateTime?     // Set when worker clocks out
  clockOutLat     Float?
  clockOutLng     Float?
  clockOutStatus  ClockInStatus?
  clockOutDistanceMiles Float?
  earlyClockOutReason   String?
  actualHours     Float?        // Computed: clockOutTime - clockInTime in hours
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  shift  Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  worker User  @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([shiftId, workerId]) // One clock-in per worker per shift
  @@index([shiftId])
  @@index([workerId])
  @@map("time_entries")
}

// ─── Subscription & Usage ────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  providerProfileId    String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  // Stripe placeholders
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model UsageTracking {
  id                String   @id @default(cuid())
  providerProfileId String
  periodStart       DateTime
  periodEnd         DateTime
  shiftsPosted      Int      @default(0)
  shiftsAssigned    Int      @default(0)
  workerUnlocks     Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  providerProfile ProviderProfile @relation(fields: [providerProfileId], references: [id], onDelete: Cascade)

  @@unique([providerProfileId, periodStart])
  @@index([providerProfileId])
  @@map("usage_tracking")
}

// ─── Marketplace Payment System ──────────────────────────────────

enum TransactionType {
  SHIFT_FUNDING     // Provider funds a shift
  PLATFORM_FEE      // Platform takes fee
  WORKER_PAYOUT     // Worker receives payout
  REFUND            // Refund to provider
  WALLET_TOPUP      // Provider adds funds to wallet
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING       // Shift completed, not yet released
  AVAILABLE     // Released, ready to withdraw
  PROCESSING    // Withdrawal in progress
  PAID          // Successfully paid out
  FAILED        // Payout failed
}

// Payment methods (cards, bank accounts)
model PaymentMethod {
  id                String   @id @default(cuid())
  userId            String
  type              String   // "card" | "bank_account"
  provider          String   @default("stripe") // payment processor
  externalId        String?  // Stripe payment method ID (pm_xxx)
  last4             String?  // Last 4 digits
  brand             String?  // visa, mastercard, etc.
  expiryMonth       Int?
  expiryYear        Int?
  bankName          String?  // For bank accounts
  isDefault         Boolean  @default(false)
  isVerified        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("payment_methods")
}

// Wallet balances for providers
model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Float    @default(0) // Available balance in USD
  reserved  Float    @default(0) // Funds reserved for active shifts
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

// All money movements through the platform
model Transaction {
  id              String            @id @default(cuid())
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Float
  platformFee     Float             @default(0)
  netAmount       Float             // amount - platformFee
  currency        String            @default("USD")
  // Relationships
  shiftId         String?
  providerId      String?
  workerId        String?
  paymentMethodId String?
  // Stripe
  stripePaymentId String?           // pi_xxx or tr_xxx
  stripeChargeId  String?
  // Metadata
  description     String?
  failureReason   String?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  shift    Shift? @relation(fields: [shiftId], references: [id])
  provider User?  @relation("ProviderTransactions", fields: [providerId], references: [id])
  worker   User?  @relation("WorkerTransactions", fields: [workerId], references: [id])

  @@index([shiftId])
  @@index([providerId])
  @@index([workerId])
  @@index([type, status])
  @@map("transactions")
}

// Per-shift payment tracking
model ShiftPayment {
  id            String            @id @default(cuid())
  shiftId       String            @unique
  providerId    String
  workerId      String?
  // Amounts
  shiftAmount   Float             // Total shift cost (hours × rate)
  platformFee   Float             @default(0) // Platform fee amount
  workerPayout  Float             @default(0) // Amount worker receives
  // Status
  fundingStatus TransactionStatus @default(PENDING) // Provider payment status
  payoutStatus  PayoutStatus      @default(PENDING)  // Worker payout status
  // Timestamps
  fundedAt      DateTime?
  completedAt   DateTime?
  paidOutAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  shift    Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  provider User  @relation("ProviderShiftPayments", fields: [providerId], references: [id])
  worker   User? @relation("WorkerShiftPayments", fields: [workerId], references: [id])

  @@index([providerId])
  @@index([workerId])
  @@index([fundingStatus])
  @@index([payoutStatus])
  @@map("shift_payments")
}

// Worker payout records
model Payout {
  id              String       @id @default(cuid())
  workerId        String
  amount          Float
  status          PayoutStatus @default(PENDING)
  paymentMethodId String?      // Worker's bank account
  stripePayoutId  String?      // po_xxx
  failureReason   String?
  processedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  worker User @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([status])
  @@map("payouts")
}

// Platform configuration
model PlatformConfig {
  id              String   @id @default(cuid())
  platformFeeRate Float    @default(0.10) // 10% default
  minPlatformFee  Float    @default(2.00) // $2 minimum
  payoutDelayHours Int     @default(48)   // Hours before payout is available
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("platform_config")
}

// ─── Notifications ───────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String    @default("")
  data      Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ─── Ratings ─────────────────────────────────────────────────────

model Rating {
  id        String   @id @default(cuid())
  shiftId   String
  raterId   String   // User who gave the rating
  rateeId   String   // User who received the rating
  score     Int      // 1-5 stars (overall, auto-computed from sub-metrics when available)
  comment   String?
  // Worker sub-metrics (filled when provider rates worker)
  punctuality     Int?  // 1-5
  professionalism Int?  // 1-5
  skillCompetence Int?  // 1-5
  // Provider sub-metrics (filled when worker rates provider)
  communication      Int?  // 1-5
  workEnvironment    Int?  // 1-5
  paymentReliability Int?  // 1-5
  fairness           Int?  // 1-5
  createdAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  rater User  @relation("RatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  ratee User  @relation("RatingsReceived", fields: [rateeId], references: [id], onDelete: Cascade)

  @@unique([shiftId, raterId]) // One rating per user per shift
  @@index([rateeId])
  @@index([raterId])
  @@map("ratings")
}

// ─── Blocked Dates (Worker Unavailability) ──────────────────────

model BlockedDate {
  id              String   @id @default(cuid())
  workerProfileId String
  date            DateTime @db.Date // The specific date blocked
  reason          String?           // Optional: "vacation", "appointment", etc.
  createdAt       DateTime @default(now())

  workerProfile WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, date])
  @@index([workerProfileId])
  @@map("blocked_dates")
}

// ─── Rate Limiting ───────────────────────────────────────────────

model RateLimitEntry {
  id          String   @id @default(cuid())
  key         String   @unique
  attempts    Int      @default(1)
  lastAttempt DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@map("rate_limit_entries")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_verification_tokens")
}

// ─── Push Subscriptions ─────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Strikes (Cancellation / No-Show Tracking) ─────────────────

model Strike {
  id        String     @id @default(cuid())
  userId    String
  type      StrikeType
  shiftId   String
  decayedAt DateTime?  // Set when 90 days of good behavior passes
  createdAt DateTime   @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, decayedAt])
  @@map("strikes")
}

// ─── Credential Expiration Alerts ───────────────────────────────

model CredentialAlert {
  id               String   @id @default(cuid())
  userId           String
  credentialId     String?  // null for provider license alerts
  daysBeforeExpiry Int      // 60, 30, 14, 7, 0
  sentAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, credentialId, daysBeforeExpiry])
  @@index([userId])
  @@map("credential_alerts")
}

// ─── Shift Messages ─────────────────────────────────────────────

model ShiftMessage {
  id        String   @id @default(cuid())
  shiftId   String
  senderId  String
  content   String   @db.Text
  createdAt DateTime @default(now())

  shift  Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  sender User  @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([shiftId, createdAt])
  @@index([senderId])
  @@map("shift_messages")
}

// ─── Preferred Workers ──────────────────────────────────────────

model PreferredWorker {
  id         String   @id @default(cuid())
  providerId String
  workerId   String
  createdAt  DateTime @default(now())

  provider User @relation("PreferredByProvider", fields: [providerId], references: [id], onDelete: Cascade)
  worker   User @relation("PreferredWorkers", fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([providerId, workerId])
  @@index([providerId])
  @@index([workerId])
  @@map("preferred_workers")
}
