# ─── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, or self-hosted)
DATABASE_URL="postgresql://user:password@localhost:5432/shiftcare?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

