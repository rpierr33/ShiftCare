# ─── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, or self-hosted)
DATABASE_URL="postgresql://user:password@localhost:5432/shiftcare?schema=public"

# ─── Admin ────────────────────────────────────────────────────────
# Comma-separated emails that can access /admin/* routes
ADMIN_EMAILS=ralph@shiftcare.com

# ─── Auth ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:4000"

# ─── Google OAuth ─────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:4000"

# ─── Stripe (Escrow Payment System) ──────────────────────────────
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Create webhook at: https://dashboard.stripe.com/webhooks
# Events: checkout.session.completed, invoice.payment_failed, customer.subscription.deleted, account.updated, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
# Create products/prices in Stripe Dashboard
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PROFESSIONAL_PRICE_ID=price_...

# ─── Email (Resend) ──────────────────────────────────────────────
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── SMS (Twilio) ────────────────────────────────────────────────
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ─── File Storage (AWS S3 for credential documents) ──────────────
# Create bucket at: https://s3.console.aws.amazon.com
S3_BUCKET=shiftcare-credentials
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ─── Google Maps (optional — falls back to OpenStreetMap) ────────
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ─── Web Push (VAPID) ──────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:push@shiftcare.com

# ─── Cron Jobs ─────────────────────────────────────────────────
# Secret token for authenticating cron job requests
CRON_SECRET=your-cron-secret-here
